{
    "compilerOptions": {
        "strict": true,
        "target": "ES2020",
        "module": "esnext",
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "types": ["node"],
        "paths": {
            "tslib": ["./node_modules/tslib/tslib.d.ts"]
        }
    },
    "ts-node": {
        "compilerOptions": {
            "module": "commonjs"
        }
    }
}
